# Higo App — variables de entorno
# Copiar a `.env` para desarrollo local: `cp .env.example .env`
# En producción se cargan desde GitHub Secrets en el workflow Deploy.

# ============================================================
# Supabase (obligatorias en CI; el cliente tiene fallback a un
# proyecto público si están vacías — útil para builds de preview
# pero NO se debe depender de eso en producción)
# ============================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<...resto del JWT...>

# ============================================================
# Google Maps JavaScript SDK (obligatoria)
# Restringida por HTTP referrer en Google Cloud Console.
# El código tiene fallback a una key pública referrer-restricted
# para evitar pantalla negra en builds sin .env.
# ============================================================
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...

# Opcional: mapId de Cloud Styling para AdvancedMarker y temas vector.
# Sin esto, los marcadores funcionan y se aplica el theme oscuro inline.
VITE_GOOGLE_MAPS_ID=

# ============================================================
# Motor de mapa (Anexo C — futuro Mapbox)
# Por defecto 'google'. Si se setea 'mapbox' el build EXIGE un token
# pk.* válido (>=60 chars) o aborta el deploy.
# ============================================================
VITE_MAP_ENGINE=google
VITE_MAPBOX_TOKEN=

# ============================================================
# Firebase / FCM (opcionales — push notifications)
# Vacías = la app arranca pero no registra el service worker FCM.
# ============================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FCM_VAPID_KEY=

# ============================================================
# Gemini (opcional, futuro)
# ============================================================
VITE_GEMINI_API_KEY=
